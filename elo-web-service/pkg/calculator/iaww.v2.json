{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elo/calculator/iaww.v2.json",
  "title": "It's a Wonderful World calculator state (v2)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "players", "direct_vp", "multipliers"],
  "properties": {
    "schema_version": { "const": 2 },
    "players": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["player_id", "name"],
        "properties": {
          "player_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "direct_vp": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["player_id", "value"],
        "properties": {
          "player_id": { "type": "string", "minLength": 1 },
          "value": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "multipliers": {
      "type": "array",
      "description": "v2: renamed row_id → row. The 'row' key holds a game-defined row identifier (e.g. 'str-res', 'structure') that is NOT an entity id, so it must NOT end in '_id' (which idcodec would rewrite). See ADR-09.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["row", "player_id", "coeff", "count"],
        "properties": {
          "row": { "type": "string", "minLength": 1 },
          "player_id": { "type": "string", "minLength": 1 },
          "coeff": { "type": "integer" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "fallback_game_id": { "type": ["string", "null"] }
  }
}
